# ──────────────────────────────────────────────────────────────────────────────
# pablofuentes.org — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# En producción (Docker) las mismas variables se leen al levantar la stack.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL — usado por el servicio `db` de docker-compose
POSTGRES_DB=pablofuentes
POSTGRES_USER=pablofuentes
POSTGRES_PASSWORD=cambia-esta-password-fuerte

# URL de conexión — en local apúntala a tu Postgres;
# en Docker el host es `db` (nombre del servicio).
DATABASE_URL="postgresql://pablofuentes:cambia-esta-password-fuerte@localhost:5432/pablofuentes?schema=public"

# NextAuth — genera una clave fuerte con:  openssl rand -base64 32
AUTH_SECRET="reemplaza-con-cadena-aleatoria-de-32+-bytes"
AUTH_URL="http://localhost:3000"
# En producción detrás de Nginx, AUTH_TRUST_HOST se inyecta en docker-compose.yml.

# Credenciales iniciales del admin — usadas por `prisma/seed.ts`
ADMIN_EMAIL="pablo@pablofuentes.org"
ADMIN_PASSWORD="Cambia-Esta-Password!"
ADMIN_NAME="Pablo Fuentes"

# Resend (opcional en dev — deja vacío y los emails se omiten)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Pablo Fuentes <newsletter@pablofuentes.org>"
CONTACT_NOTIFY_EMAIL="pablo@pablofuentes.org"

# Pública — URL canónica del sitio (usada en metadata, OG, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
